{
  "name": "laon-focus-app",
  "version": "1.0.0",
  "description": "Laon Focus App - ADHD 친화적 TODO 관리 앱 with Notion API",
  "main": "src/electron.js",
  "scripts": {
    "react-start": "webpack serve --mode development --config webpack.config.js",
    "react-build": "webpack --mode production --config webpack.config.js",
    "electron-start": "electron .",
    "dev": "concurrently \"npm run react-start\" \"wait-on http://localhost:3000 && npm run electron-start\"",
    "build": "npm run react-build && electron-builder",
    "create-sample-data": "node scripts/create-sample-data.js"
  },
  "build": {
    "appId": "com.laon.focus",
    "productName": "Laon Focus App",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "public/laon_icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/laon_icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    },
    "files": [
      "src/electron.js",
      "src/preload.js",
      "src/auth/**/*",
      "build/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist"
    }
  },
  "dependencies": {
    "@notionhq/client": "^2.2.14",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^3.3.4",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.3",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.2"
  }
}
